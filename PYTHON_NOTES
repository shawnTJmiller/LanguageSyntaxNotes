### Config Manager Example:
test_settings = {
    'theme': 'dark',
    'language': 'english',
    'notifications': 'enabled'
}

def add_setting(settings: dict[str, str], pair: tuple[str, str]) -> str:
    key, value = pair
    key_lc = str(key).lower()
    value_lc = str(value).lower()

    if key_lc in settings:
        return f"Setting '{key_lc}' already exists! Cannot add a new setting with this name."
    
    settings[key_lc] = value_lc
    return f"Setting '{key_lc}' added with value '{value_lc}' successfully!"

def update_setting(settings: dict[str, str], pair: tuple[str, str]) -> str:
    key, value = pair
    key_lc = str(key).lower()
    value_lc = str(value).lower()

    if key_lc not in settings:
        return f"Setting '{key_lc}' does not exist! Cannot update a non-existing setting."

    settings[key_lc] = value_lc
    return f"Setting '{key_lc}' updated to '{value_lc}' successfully!"

def delete_setting(settings: dict[str, str], key: str) -> str:
    key_lc = str(key).lower()

    if key_lc in settings:
        del settings[key_lc]
        return f"Setting '{key_lc}' deleted successfully!"

    return "Setting not found!"

def view_settings(settings: dict[str, str]) -> str:
    if not settings:
        return "No settings available."
    
    display = "Current User Settings:\n"
    for key in settings:
        display += f"{key.capitalize()}: {settings[key]}\n"
    return display