/*  WHAT IS A PROMISE?
    In JavaScript, a promise is an object that represents a value that might not be available yet.
    It will be resolved in the future, either successfully or with an error.
    It allows you to write asychronous code that can handle the results when they become available.
*/

/*  FUN FACTS ABOUT PROMISES:
    1. Promises were introduced in ECMAScript 2015 (ES6).
    2. A promise can be in one of three states: pending, resolved, or rejected.
    3. Promises can be chained together using .then() for better readability and error handling.
    4. Promises help simplify asynchronous code by allowing code that depends on the result of asynchronous operations.
    5. Promises are not the only way to handle asynchronous operations but they are popular and widely used in modern JavaScript.
    6. The Promise API includes methods like Promise.all() and Promise.race() for handling multiple promises simultaneously.
*/

/*  WHEN TO USE PROMISES:
    1. When you need to make a small number of asynchronous calls that are simple to manage.
    2. When you need to perform a sequence of asynchronous operations where each operation depends on the result of the previous one.
    3. When you need to execute multiple asynchronous operations in parallel and wait for all of them to complete before proceeding.
    4. When you want to improve the readability of your asynchronous code and avoid callback hell.
    5. When you want to handle errors in a more structured way using .catch() instead of nested callbacks.
    6. When you want to take advantage of the built-in Promise methods for handling multiple promises or creating custom promise-based APIs.
*/

/*  WHEN TO AVOID PROMISES:
    1. When you are working with older JavaScript environments that don't support promises natively.
    2. When you have simple synchronous operations that don't involve delays or external dependencies.
    3. When you have a large number of asynchronous calls that are complex to manage with promises.
    4. When you need more control over the execution flow than what promises provide.
*/

// EXAMPLE_1 of a Promise
const myPromise = new Promise((resolve, reject) => {
    // Simulating an asynchronous operation
    setTimeout(() => {
        const success = Math.random() > 0.5;
        if (success) {
            resolve("Operation completed successfully!");
        } else {
            reject("Operation failed!");
        }
    }, 1000);
});

// Handling the Promise
myPromise
    .then(result => {
        console.log(result);
    })
    .catch(error => {
        console.error(error);
    });
// Output will be either "Operation completed successfully!" or "Operation failed!" after 1 second, depending on the random outcome.

// EXAMPLE_2 of a Promise with chaining
const fetchData = () => {
    return new Promise((resolve, reject) => {
        setTimeout(() => {
            const data = { id: 1, name: "John Doe" };
            resolve(data);
        }, 1000);
    });
};

fetchData()
    .then(data => {
        console.log(data);
    })
    .catch(error => {
        console.error(error);
    });
// Output will be { id: 1, name: "John Doe" } after 1 second.

// EXAMPLE_3 of a Promise with URL API call
const fetchUserData = (userId) => {
    return new Promise((resolve, reject) => {
        fetch(`https://jsonplaceholder.typicode.com/users/${userId}`)
            .then(response => {
                if (!response.ok) {
                    throw new Error("Failed to fetch user data");
                }
                return response.json();
            })
            .then(data => {
                resolve(data);
            })
            .catch(error => {
                reject(error);
            });
    });
};

fetchUserData(1)
    .then(data => {
        console.log(data);
    })
    .catch(error => {
        console.error(error);
    });
// Output will be the user data for user with id 1 from the JSONPlaceholder API.

// EXAMPLE_4 of a Promise with async/await syntax
const fetchUserDataAsync = async (userId) => {
    try {
        const response = await fetch(`https://jsonplaceholder.typicode.com/users/${userId}`);
        if (!response.ok) {
            throw new Error("Failed to fetch user data");
        }
        const data = await response.json();
        return data;
    } catch (error) {
        console.error(error);
        throw error;
    }
};

fetchUserDataAsync(1)
    .then(data => {
        console.log(data);
    })
    .catch(error => {
        console.error(error);
    });
// Output will be the user data for user with id 1 from the JSONPlaceholder API, using async/await syntax.

// EXAMPLE_5 of a Promise with Promise.all()
const fetchMultipleUsers = (userIds) => {
    const promises = userIds.map(id => fetchUserData(id));
    return Promise.all(promises);
};

fetchMultipleUsers([1, 2, 3])
    .then(users => {
        console.log(users);
    })
    .catch(error => {
        console.error(error);
    });
// Output will be an array of user data for users with ids 1, 2, and 3 from the JSONPlaceholder API.

// EXAMPLE_6 of a Promise with Promise.race()
const fetchWithTimeout = (url, timeout) => {
    return new Promise((resolve, reject) => {
        const timer = setTimeout(() => {
            reject(new Error("Request timed out"));
        }, timeout);
        fetch(url)
        .then(response => {
            clearTimeout(timer);
            if (!response.ok) {
                throw new Error("Failed to fetch data");
            }
            return response.json();
        })
        .then(data => {
            resolve(data);
        })
        .catch(error => {
            clearTimeout(timer);
            reject(error);
        });
    });
};

fetchWithTimeout("https://jsonplaceholder.typicode.com/users/1", 500)
    .then(data => {
        console.log(data);
    })
    .catch(error => {
        console.error(error);
    });
// Output will be either the user data for user with id 1 from the JSONPlaceholder API or an error message "Request timed out" if the request takes longer than 500 milliseconds.

// EXAMPLE_7 of a Promise with custom promise-based API
const delay = (ms) => {
    return new Promise((resolve) => {
        setTimeout(() => {
            resolve(`Delayed for ${ms} milliseconds`);
        }, ms);
    });
};

delay(2000)
    .then(message => {
        console.log(message);
    });
// Output will be "Delayed for 2000 milliseconds" after 2 seconds.

