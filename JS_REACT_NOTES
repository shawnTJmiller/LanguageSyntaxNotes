/*
Q: How does React handle prop drilling, and how can it be avoided?
A: Prop drilling is the process of passing props through multiple levels of components to reach a deeply nested component.
React handles prop drilling by allowing props to pass down the component tree, leading to cumbersome and difficult to maintain code.
To avoid prop drilling, use context or state management solutions like Redux or React's Context API.
These allow shared data across components without passing props down manually at every level.
*/

/*
Q: What is Redux and why is it used?
A: Redux is a state management library for JavaScript applications, often used with React.
It provides a predictable state container that helps manage the state of an application in a consistent way.
Redux allows you to centralize your application's state and logic, making it easier to debug and test.
It uses a unidirectional data flow, where actions are dispatched to update the state, and components subscribe to changes in the state.
Redux is particularly useful for larger applications with complex state management needs.
*/
// An example of using Redux:
const initialState = { count: 0 };
function reducer(state = initialState, action) {
    switch (action.type) {
        case 'INCREMENT':
            return { count: state.count + 1 };
        default:
            return state;
    };
}
        
const store = createStore(reducer);
store.dispatch({ type: 'INCREMENT' });
console.log(store.getState()); // { count: 1 }

/*
Q: How does React handle forms?
A: React handles forms using controlled components, where the form elements are controlled by React state.
The value of the input is set by the state, and any changes to the input are handled through event handlers that update the state.
This allows you to have more control over the form data and perform validation or conditional rendering based on the input values.
*/
// An example of a controlled form component:
function MyForm() {
    const [value, setValue] = useState('');
    const handleChange = (e) => {
        setValue(e.target.value);
    };

    const handleSubmit = (e) => {
        e.preventDefault();
        alert('Form submitted with value: ' + value);
    };

    return (
        <form onSubmit={handleSubmit}>
            <input type="text" value={value} onChange={handleChange} />
        </form>
    );
}

/*
Q: What is the difference between controlled and uncontrolled components in React?
A: Controlled components are form elements that are controlled by React state.
The value of the input is set by the state, and any changes to the input are handled through event handlers that update the state.
Uncontrolled components are form elements that manage their own state internally. You can access their values using refs.
Controlled components provide more control over the form data and allow for validation and conditional rendering, while uncontrolled components can be simpler to implement for basic use cases.
*/
// Examples of a controlled and uncontrolled component:
function ControlledComponent() {
    const [value, setValue] = useState('');
    const handleChange = (e) => {
        setValue(e.target.value);
    };
    return (
        <input type="text" value={value} onChange={handleChange} />
    );
}

function UncontrolledComponent() {
    const inputRef = React.createRef();
    const handleSubmit = () => {
        alert(inputRef.current.value);
    };
    return (
        <div>
            <input type="text" ref={inputRef} />
            <button onClick={handleSubmit}>Submit</button>
        </div>
    );
}

