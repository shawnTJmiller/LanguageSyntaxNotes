/*
Q: What is the purpose of the useEffect hook's cleanup function?
A: The cleanup function in useEffect is used to perform cleanup tasks when a component unmounts or before the effect runs again.
This is useful for tasks like clearing timers, canceling network requests, or unsubscribing from subscriptions that were set up.
*/
// An example of using the cleanup function in useEffect:
function MyComponent() {
    useEffect(() => {
        const timer = setTimeout(() => {
            console.log('Timer expired');
        }, 1000);
        return () => {
            clearTimeout(timer);
            console.log('Cleanup function called');
        };
    }, []);
    return <p>My Component</p>;
}

/*
Q: What is the purpose of the useLayoutEffect hook in React?
A: The useLayoutEffect hook is similar to useEffect, but it fires synchronously after all DOM mutations.
This means that it runs before the browser has a chance to paint, allowing you to make DOM measurements or mutations before the user sees the changes.
useLayoutEffect is useful for tasks that require immediate updates to the DOM, such as measuring the size of an element or synchronously updating the layout.
*/
// An example of using useLayoutEffect:
function MyComponent() {
    const [width, setWidth] = useState(0);
    const divRef = useRef(null);
    useLayoutEffect(() => {
        setWidth(divRef.current.offsetWidth);
    }, []);
    return <div ref={divRef}>Width: {width}px</div>;
}

/*
Q: What is the purpose of the useImperativeHandle hook in React?
A: The useImperativeHandle hook is used to customize the instance value that is exposed to parent components when using forwardRef.
This allows you to control what methods or properties are accessible to the parent component when it uses a ref to interact with the child.
*/
// An example of using useImperativeHandle:
const MyComponent = React.forwardRef((props, ref) => {
    const inputRef = useRef();
    useImperativeHandle(ref, () => ({
        focus: () => {
            inputRef.current.focus();
        }
    }));
    return <input ref={inputRef} type="text" />;
});

/*
Q: What is the purpose of the useDebugValue hook in React?
A: The useDebugValue hook is used to display a label for custom hooks in React DevTools.
This can help with debugging by providing more context about the state or behavior of a custom hook when inspecting it in the DevTools.
You can use useDebugValue to show the current value of a custom hook or any relevant information that can assist in debugging.
*/
// An example of using useDebugValue:
function useCustomHook(value) {
    const [state, setState] = useState(value);
    useDebugValue(state);
    return [state, setState];
}

